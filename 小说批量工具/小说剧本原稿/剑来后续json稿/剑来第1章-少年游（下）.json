  "data": [
    {"id":0,"role":"旁白","api":{"voice":{"text":"白发童子目瞪口呆，伤心欲绝道：不能够啊，我对隐官老祖和郭盟主都是忠心耿耿，日月可鉴的，谢舵主忘了我们一起铺路造桥、开垦良田的情谊了？","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述白发童子的反应"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":1,"role":"陈平安","api":{"voice":{"text":"留职观察好了。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"笑着解围"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":2,"role":"旁白","api":{"voice":{"text":"郭竹酒笑眯起眼，谢狗低声说了句狗屎运，白发童子刚要振臂高呼与隐官老祖说几句肺腑之言，却见崔东山抬了抬手掌、一副你可以开始展现演技的贱兮兮模样，白发童子便立即停下了动作，眼珠子滴溜溜转动起来，想着总要找回场子才行。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述众人反应"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":3,"role":"陈平安","api":{"voice":{"text":"趁着今夜人多，不如等我从京城返回，一起吃过宵夜，酒足饭饱，我们趁热打铁，连夜开一场祖师堂议事？","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"提议"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":4,"role":"陈平安","api":{"voice":{"text":"何况小米粒和陈灵均，还有钟倩明儿就要外出游历了，总要合计合计。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"解释原因"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":5,"role":"旁白","api":{"voice":{"text":"自然没有什么异议。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":6,"role":"旁白","api":{"voice":{"text":"拜剑台那边，只有齐廷济，米裕，还有竹素，他们三位剑修赶来集灵峰这边。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述场景"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":7,"role":"旁白","api":{"voice":{"text":"陈平安与两次闭关都必须让道的竹素道了歉。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":8,"role":"竹素","api":{"voice":{"text":"宗主近期？","role":"竹素","role_voice":"云杰-男青年","speed":"-3%","volume":"0%","pitch":"+2Hz","instruct":"满脸无奈，小心翼翼询问"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":9,"role":"陈平安","api":{"voice":{"text":"只管闭关。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"赧颜"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":10,"role":"竹素","api":{"voice":{"text":"再来一次，我可真就没有信心闭关了，想都不敢想破境了。","role":"竹素","role_voice":"云杰-男青年","speed":"-3%","volume":"0%","pitch":"+2Hz","instruct":"直截了当"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":11,"role":"宁姚","api":{"voice":{"text":"你只管去湖边闭关，我来替你护关。","role":"宁姚","role_voice":"云夏-女青年","speed":"-1%","volume":"-1%","pitch":"+4Hz","instruct":"坚定"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":12,"role":"竹素","api":{"voice":{"text":"宁姚，我就等你这句话呢。","role":"竹素","role_voice":"云杰-男青年","speed":"-3%","volume":"0%","pitch":"+2Hz","instruct":"蓦然而笑"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":13,"role":"旁白","api":{"voice":{"text":"就陈隐官这路数，估计齐廷济帮忙护关都靠不牢，唯有宁姚出面，竹素才算吃了颗定心丸。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":14,"role":"陈平安","api":{"voice":{"text":"齐老剑仙，你也别净身出户了，不如在龙象剑宗继续挂个名，比如当个供奉？不然我们现在的顶尖战力，好像不太够看啊。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"玩笑"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":15,"role":"齐廷济","api":{"voice":{"text":"我若是哪天能够跻身十四境，就挂名，否则就不充数了，丢不起这个脸。","role":"齐廷济","role_voice":"云泽-男中年","speed":"-6%","volume":"0%","pitch":"-5Hz","instruct":"笑道"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":16,"role":"崔东山","api":{"voice":{"text":"先生，我们周首席想要升个官，捞个副山主当当，他说只有这样，才敢去书简湖兼任下宗的宗主。","role":"崔东山","role_voice":"云扬-男青年","speed":"+2%","volume":"+2%","pitch":"+3Hz","instruct":"见缝插针"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":17,"role":"陈平安","api":{"voice":{"text":"也好，空出来的落魄山首席供奉之位，刚好可以预留给齐老剑仙。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"点头"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":18,"role":"掌律长命","api":{"voice":{"text":"今夜霁色峰祖师堂议事，刚好把这件事定下来，周首席更换身份，多出来的首席，先将齐老剑仙的名字补上，就当是预祝跻身十四境。","role":"掌律长命","role_voice":"云泽-男中年","speed":"-5%","volume":"0%","pitch":"-4Hz","instruct":"提议"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":19,"role":"齐廷济","api":{"voice":{"text":"别赶鸭子上架，不吃你们这套。","role":"齐廷济","role_voice":"云泽-男中年","speed":"-6%","volume":"0%","pitch":"-5Hz","instruct":"摆摆手"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":20,"role":"陈平安","api":{"voice":{"text":"首席供奉，还是给谢次席好了。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"笑道"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":21,"role":"谢狗","api":{"voice":{"text":"如此安排座位，也算名至实归。","role":"谢狗","role_voice":"云杰-男青年","speed":"0%","volume":"+1%","pitch":"+1Hz","instruct":"揉了揉貂帽，咳嗽几声润了润嗓子"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":22,"role":"旁白","api":{"voice":{"text":"之后让魏檗帮忙，不让小陌和谢狗跟着，陈平安恳请先生一定要留在山中，等到老秀才抚须颔首，陈平安这才单独去了京城。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"静夜星空","scene_cn":"古风静夜，轻柔古琴","scene_en":"Ancient Chinese quiet night, gentle guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":23,"role":"旁白","api":{"voice":{"text":"却不是直接去往老莺湖，而是京畿之地的青玄洞。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"switch","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":1,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":24,"role":"旁白","api":{"voice":{"text":"这片地界山水幽静，距离适中，太远了就成了名副其实的出门远游，太近了就会拥堵，哪里是人看风景，山水看人才对。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述青玄洞环境"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":25,"role":"旁白","api":{"voice":{"text":"故而京城显贵的亲眷经常来此郊游，经常能见到七八肩油碧舆，官宦妇人们悠游于山林，尤其是盛夏时节，道旁古木，树荫滴翠，高影密荫，午日俱碧。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":26,"role":"旁白","api":{"voice":{"text":"若是能够寻一处视野开阔的地方，搭棚纳凉，既能够远眺京城轮廓，身后便是清风习习，深木筛金。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":27,"role":"旁白","api":{"voice":{"text":"猿蹂栈这边的青玄洞外边，却是人迹罕至。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"转折"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":28,"role":"旁白","api":{"voice":{"text":"黄花神再次从那只青铜鼎中探出头颅，夜深人静，月光如水，总觉得像是个适合脚底抹油的良辰吉时。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述黄花神"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":29,"role":"旁白","api":{"voice":{"text":"却觉得背脊发凉，转头望去，黄花神瞧见了一个双手插袖的青衫男子，后者开口说道：道友真有闲情逸致，大晚上泡澡。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述相遇场景"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":30,"role":"黄花神","api":{"voice":{"text":"道友名讳？","role":"黄花神","role_voice":"云杰-男青年","speed":"0%","volume":"-1%","pitch":"-1Hz","instruct":"询问，略带警惕"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":31,"role":"陈平安","api":{"voice":{"text":"乌桕道友，说说看大致过程，就从你见着顾璨那一刻说起，前边的，我不太感兴趣。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"直接点明来意"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":32,"role":"旁白","api":{"voice":{"text":"黄花神心中了然，多半是那位了。再不敢隐瞒什么，黄花神将前因后果速速道出，原来顾璨与郑居中的对话，都没瞒着锅里煮着的乌桕道友，听得黄花神心有余悸，真怕被顾璨给杀人灭口了。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":33,"role":"旁白","api":{"voice":{"text":"之后便是顾璨莫名其妙被郑居中用几句话给逼死了，再后边，黄花神刚想要离开这处是非之地，至于这口青铜大鼎，倒也想一起顺走……结果一个相貌平平的男人火急火燎御剑赶来这边，与他问了些问题。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":34,"role":"旁白","api":{"voice":{"text":"黄花神照实说了，大抵就是师徒因为那个姓陈的，反目成仇了，顾璨落了个自尽的下场，撩了几句好似遗言的狠话给这人间……","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":35,"role":"旁白","api":{"voice":{"text":"之后黄花神就看到那位剑修跟睡着了似的，醒过来之后，很快就流了鼻血。再打瞌睡，身形摇晃，七窍流血。还要继续……","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":36,"role":"旁白","api":{"voice":{"text":"为何如此古怪作为，黄花神看不出缘由，只觉得这个剑修，也是个狠人。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":37,"role":"旁白","api":{"voice":{"text":"不过黄花神当时就猜出了剑修的身份，骊珠洞天年轻一辈当中的刘陈顾嘛。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":38,"role":"旁白","api":{"voice":{"text":"一边言语解释，一边悉心观察那位年轻国师的神色变化，可惜对方没有表情，黄花神无法凭此揣度他的真实性格，心境变化。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":39,"role":"旁白","api":{"voice":{"text":"先前黄花神好不容易熬过了三昧真火的一场烹煮，将那鼎盖给挪开了摔在地上，此刻蹲在鼎内，探出脑袋。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":40,"role":"旁白","api":{"voice":{"text":"却见那青衫男子脚尖一挑，将那鼎盖高高跳起，伸手抓住，就要往自己脑袋上盖过来……","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述动作"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":41,"role":"黄花神","api":{"voice":{"text":"道友这是作甚？！","role":"黄花神","role_voice":"云杰-男青年","speed":"0%","volume":"-1%","pitch":"-1Hz","instruct":"假装不认得，慌张"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":42,"role":"陈平安","api":{"voice":{"text":"等了半天，道友你也不出来，便觉得道友约莫是想用古怪路数修炼道法……","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"将鼎盖压下"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":43,"role":"黄花神","api":{"voice":{"text":"道友误会了，我自然是想出来的，这种修炼法门比较……","role":"黄花神","role_voice":"云杰-男青年","speed":"0%","volume":"-1%","pitch":"-1Hz","instruct":"伸出手掌死死抵住鼎盖，绞尽脑汁解释"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":44,"role":"陈平安","api":{"voice":{"text":"也看时辰？","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"接话"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":45,"role":"黄花神","api":{"voice":{"text":"对，道友见解不俗，如你所说，过了时辰，便事倍功半了。","role":"黄花神","role_voice":"云杰-男青年","speed":"0%","volume":"-1%","pitch":"-1Hz","instruct":"恍然"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":46,"role":"陈平安","api":{"voice":{"text":"你就是黄花神吧，如今在书简湖素鳞岛田湖君那边混饭吃？","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"松开手，询问"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":47,"role":"黄花神","api":{"voice":{"text":"是我贻笑大方了，瞒不过陈国师。","role":"黄花神","role_voice":"云杰-男青年","speed":"0%","volume":"-1%","pitch":"-1Hz","instruct":"脸色尴尬，双手托住鼎盖"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":48,"role":"陈平安","api":{"voice":{"text":"你就在这边等着，等到了你先生顾璨是最好，等不到你就别出来了。你要是不信，大可以试试看。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"语气平静"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":49,"role":"黄花神","api":{"voice":{"text":"陈国师何必与我这种散修一般见识。","role":"黄花神","role_voice":"云杰-男青年","speed":"0%","volume":"-1%","pitch":"-1Hz","instruct":"苦笑"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":50,"role":"陈平安","api":{"voice":{"text":"知不知道当年书简湖，拢共有几个玉璞境野修？我不与你一般见识，跟谁一般见识去？田湖君？","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"微笑"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":51,"role":"旁白","api":{"voice":{"text":"黄花神脸色悲苦，早知道就不来大骊京城凑热闹了。与那先生顾璨，黄花神内心深处，还不太服输，只是对上眼前这位，黄花神还真没有半点较劲的心思。无论心计还是修为，或是手腕，都是敌不过的。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述黄花神心态"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":52,"role":"旁白","api":{"voice":{"text":"陈平安也不管黄花神，走到崖畔，眺望夜幕中的大骊京城，一国首善之地，人烟稠密之处，自然尤其灯火璀璨。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述场景"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":53,"role":"旁白","api":{"voice":{"text":"人间尚未真正迎来太平世道，五座天下的山上，甚至可能会变得更加混乱，但是对与错，都是人间自己的自由。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"感慨"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":54,"role":"旁白","api":{"voice":{"text":"下意识去掏出那枚当了很多年酒葫芦的养剑葫，才发现已经损毁于那场天地通中，陈平安顿时心疼不已，却也谈不上遗憾。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":55,"role":"旁白","api":{"voice":{"text":"遑遑三十载，书剑两不成。欲买桂花同载酒，终不似，少年游。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"念诵诗句，感慨"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-20%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":56,"role":"旁白","api":{"voice":{"text":"不过山中学道人只要长远看，别说是三十载，就算三百载，甚至是三千载，后边一段回看前一段，不也是一场新的少年游？","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"释然"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":57,"role":"旁白","api":{"voice":{"text":"内心微动，陈平安抬头望向天幕，只见一道璀璨剑光略作停顿，好像在认路，剑光骤然更快，来到宝瓶洲这边。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":58,"role":"旁白","api":{"voice":{"text":"黄花神在内心求爷爷告奶奶，可能要比那位青衫男子更希望顾璨能够活着回来青玄洞。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":59,"role":"刘羡阳","api":{"voice":{"text":"喜欢自个儿逞英雄是吧？！","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"一屁股坐在地上，抖了抖袖子，勒住陈平安脖子"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":60,"role":"陈平安","api":{"voice":{"text":"掐死我了，谁给你婚礼当伴郎。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"赶忙拍刘羡阳胳膊"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":61,"role":"顾璨","api":{"voice":{"text":"没了一心为民除害的大英雄，单枪匹马慷慨赴死的大豪杰，不还有我可以当伴郎。实在不行，我就让刘羡阳，把刻有名字的牌位往桌上一放，就当是用刘羡阳的婚礼红事给白事冲喜了……","role":"顾璨","role_voice":"云-男青年多语言","speed":"-3%","volume":"0%","pitch":"-2Hz","instruct":"雾影，没好气"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":62,"role":"旁白","api":{"voice":{"text":"刘羡阳哈哈大笑，这辈子还是头回听见顾璨站在自己身边，一起对付陈平安。看来心里边气不小。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":63,"role":"旁白","api":{"voice":{"text":"陈平安抬起手心揉了揉下巴，也没还嘴。顾璨自己却是气势弱了，最终闭嘴不言。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":64,"role":"旁白","api":{"voice":{"text":"黄花神依旧站在鼎内，哪敢插话，此刻倒是后悔没有将鼎盖放好。只求着他们几个同乡挚友都忘了自己，顾璨最好把青铜大鼎也忘记带走，一并留下……","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":65,"role":"陈平安","api":{"voice":{"text":"过两天的婚礼肯定是要一起参加的。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"微笑"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":66,"role":"陈平安","api":{"voice":{"text":"以后大斩蛮荒，你们也可以一起，暂定。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"平静"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":67,"role":"陈平安","api":{"voice":{"text":"至于问剑白玉京的个人恩怨，得看你们当时的境界了，再说。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"平静"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":68,"role":"旁白","api":{"voice":{"text":"既然已经解决掉了周密这个名副其实的天大隐患，先前好些布置，就是废纸一堆了。接下来，大致就是小游宝瓶洲，大游浩然天下，提升境界，为将来做客青冥天下做准备。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":69,"role":"刘羡阳","api":{"voice":{"text":"我这边肯定没半点问题啊，顾宗主毕竟资质差了点，现在又是这副模样，估计只能跟乌桕道友似的，站在某个地方，大声喝彩，拍手叫好。","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"牛气哄哄"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":70,"role":"旁白","api":{"voice":{"text":"黄花神笑容牵强，你们几个都是做大事壮举、立大功业的人物，扯上我做什么，好没意思的。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":71,"role":"刘羡阳","api":{"voice":{"text":"乌桕道友，需不需要我帮你往鼎里加点水，再添把柴火？","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"转头笑问"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":72,"role":"旁白","api":{"voice":{"text":"黄花神身体僵硬，摇摇头。陈平安看了眼黄花神，顾璨模样的雾影显然也在斜睨这位学生。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":73,"role":"刘羡阳","api":{"voice":{"text":"难做人，好死鬼。","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"笑道"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":74,"role":"黄花神","api":{"voice":{"text":"我立即就回书简湖，好好做人，一心向道。","role":"黄花神","role_voice":"云杰-男青年","speed":"0%","volume":"-1%","pitch":"-1Hz","instruct":"头皮发麻，承诺"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":75,"role":"刘羡阳","api":{"voice":{"text":"就这样吧，慢慢来吧。","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"叹气，拍陈平安肩膀"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":76,"role":"顾璨","api":{"voice":{"text":"那你跟宁姚呢，就这么一直拖着？","role":"顾璨","role_voice":"云-男青年多语言","speed":"-3%","volume":"0%","pitch":"-2Hz","instruct":"找回场子"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":77,"role":"陈平安","api":{"voice":{"text":"废什么话。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"瞪眼"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":78,"role":"刘羡阳","api":{"voice":{"text":"怎么就是废话了，家乡习俗啊，本来就只有等大哥成亲了，再轮到老二婚配，之后才能轮到老三，顾璨心急。","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"笑道"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":79,"role":"顾璨","api":{"voice":{"text":"滚一边去。","role":"顾璨","role_voice":"云-男青年多语言","speed":"-3%","volume":"0%","pitch":"-2Hz","instruct":"骂道"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":80,"role":"陈平安","api":{"voice":{"text":"我先生说了，此次三教辩论，题目就两个字。我是不参加了，你们如果有兴趣，我可以帮你们讨要名额。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"想起一事"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":81,"role":"刘羡阳","api":{"voice":{"text":"啥议题？","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"好奇"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":82,"role":"顾璨","api":{"voice":{"text":"末法。","role":"顾璨","role_voice":"云-男青年多语言","speed":"-3%","volume":"0%","pitch":"-2Hz","instruct":"淡然"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":83,"role":"刘羡阳","api":{"voice":{"text":"果然跟我想的一样。","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"点头"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":84,"role":"旁白","api":{"voice":{"text":"顾璨发出吐痰的声响。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":85,"role":"刘羡阳","api":{"voice":{"text":"陈平安，狐国都是你家的，有没有多余的狐皮美人符箓，我把顾璨的魂魄塞进去，到时候他跟侍女一起端茶送水，那画面……咦，不对啊，有些大材小用了，好像顾璨都可以假扮伴娘了……","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"好奇询问"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":86,"role":"旁白","api":{"voice":{"text":"顾璨开始骂起刘羡阳的祖宗十八代，刘羡阳呲牙咧嘴，倒不是嫌难听，而是觉得小鼻涕虫的功力退步了。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":87,"role":"陈平安","api":{"voice":{"text":"你们先回龙泉剑宗，我得去趟大骊京城了。除了朱敛这个厨子，我还让人把贾老神仙喊过来了，去你们那边搭把手。","role":"陈平安","role_voice":"云-男青年多语言","speed":"-2%","volume":"0%","pitch":"0Hz","instruct":"安排"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":88,"role":"刘羡阳","api":{"voice":{"text":"还算你小子有点良心，都是一等一的精兵强将啊！","role":"刘羡阳","role_voice":"云杰-男青年","speed":"+1%","volume":"+1%","pitch":"+2Hz","instruct":"拍掌赞叹"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-22%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":89,"role":"旁白","api":{"voice":{"text":"朱敛的厨艺，没的说，一绝。贾老神仙对于各种乡俗规矩，更是行家里手。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"叙述"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}},
    {"id":90,"role":"旁白","api":{"voice":{"text":"陈平安脚尖一点，武学宗师覆地远游，好像有意贴近人间些许，身形清灵如鸟雀翩跹在山野枝头间。","role":"旁白","role_voice":"云健-中年男性磁性声音","speed":"-10%","volume":"0%","pitch":"0Hz","instruct":"描述动作"},"bgm":{"play_mode":"keep","scene":"悬念氛围","scene_cn":"神秘古风，低沉古琴","scene_en":"Mysterious ancient style, deep guqin","fade_in":0,"fade_out":0,"volume":"-18%","pitch":"+0Hz"},"effects":[]},"mix":{"mode":"voice_on_bgm"}}
  ]
